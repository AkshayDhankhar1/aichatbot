# ---- LLM (Groq, free tier) ----
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# ---- Pinecone (free tier) ----
PINECONE_API_KEY=
PINECONE_INDEX_NAME=crm-rag
# Cloud/region for a serverless index (created automatically by ingest if missing).
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1

# ---- Embeddings (local sentence-transformers, 384 dims) ----
# Index dimension MUST match this model's output (all-MiniLM-L6-v2 -> 384).
EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2

# ---- Retrieval / hybrid search tuning ----
# alpha=1.0 -> pure dense, 0.0 -> pure sparse/BM25. 0.5 = balanced hybrid.
HYBRID_ALPHA=0.5
# How many chunks to pull from Pinecone.
TOP_K=8
# How many top chunks to actually feed the LLM.
TOP_N=4
# Anti-hallucination gate: if the best chunk score is below this, answer
# "not in the documents" instead of generating. Tune to your corpus.
MIN_SCORE_THRESHOLD=0.15

# ---- CORS ----
# Comma-separated. Add your deployed Vercel URL here after deploying the frontend.
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
